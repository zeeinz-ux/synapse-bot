# Copy file ini jadi .env dan isi dengan data kamu
# JANGAN commit file .env ke GitHub!

# Discord Bot Token
token_bot=your_discord_bot_token_here

# Firebase (Mode 1: path file | Mode 2: JSON string 1 baris)
FIREBASE_KEY=serviceAccountKey.json

# Spotify API (opsional, untuk fitur Spotify)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
